<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <template class="BookTxtParseDialog" parent="AdwPreferencesDialog">
    <property name="title" translatable="yes">TXT parse rules</property>
    <child>
      <object class="AdwPreferencesPage">
        <child>
          <object class="AdwPreferencesGroup" id="grp_custom">
            <property name="title" translatable="yes">Custom rules for this book</property>
            <property name="description" translatable="yes">If the custom rules do not match, Heartale will try the global rules.</property>
            <child>
              <object class="AdwEntryRow" id="row_volume">
                <property name="title" translatable="yes">Volume pattern</property>
              </object>
            </child>
            <child>
              <object class="AdwEntryRow" id="row_chapter">
                <property name="title" translatable="yes">Chapter pattern</property>
              </object>
            </child>
          </object>
        </child>

        <child>
          <object class="AdwPreferencesGroup" id="grp_actions">
            <child>
              <object class="AdwActionRow" id="row_save">
                <property name="title" translatable="yes">Save</property>
                <property name="activatable-widget">btn_save</property>
                <child type="suffix">
                  <object class="GtkButton" id="btn_save">
                    <property name="label" translatable="yes">Save</property>
                    <property name="margin-top">6</property>
                    <property name="margin-bottom">6</property>
                    <property name="margin-start">6</property>
                    <property name="margin-end">6</property>
                    <signal name="clicked" handler="_on_save_clicked"/>
                    <style>
                      <class name="suggested-action" />
                    </style>
                  </object>
                </child>
              </object>
            </child>

            <child>
              <object class="AdwActionRow" id="row_clear">
                <property name="title" translatable="yes">Clear custom rules</property>
                <property name="activatable-widget">btn_clear</property>
                <child type="suffix">
                  <object class="GtkButton" id="btn_clear">
                    <property name="label" translatable="yes">Clear</property>
                    <property name="margin-top">6</property>
                    <property name="margin-bottom">6</property>
                    <property name="margin-start">6</property>
                    <property name="margin-end">6</property>
                    <signal name="clicked" handler="_on_clear_clicked"/>
                    <style>
                      <class name="destructive-action" />
                    </style>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </template>
</interface>
