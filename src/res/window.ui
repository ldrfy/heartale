<?xml version='1.0' encoding='UTF-8'?>
<!-- Created with Cambalache 0.96.1 -->
<interface>
  <!-- interface-name window.ui -->
  <requires lib="adw" version="1.4"/>
  <requires lib="gtk" version="4.12"/>
  <requires lib="libadwaita" version="1.4"/>
  <template class="HeartaleWindow" parent="AdwApplicationWindow">
    <property name="default-height">700</property>
    <property name="default-width">1024</property>
    <property name="title" translatable="yes">Heartale</property>
    <child>
      <object class="GtkOverlay">
        <property name="child">
          <object class="AdwToastOverlay" id="toasts">
            <property name="child">
              <object class="AdwNavigationView" id="nav">
                <signal name="notify::visible-page" handler="on_visible_page_changed"/>
              </object>
            </property>
          </object>
        </property>
        <child type="overlay">
          <object class="GtkButton" id="btn_global_tts_stop">
            <property name="halign">end</property>
            <property name="valign">end</property>
            <property name="margin-end">48</property>
            <property name="margin-bottom">36</property>
            <property name="icon-name">media-playback-stop-symbolic</property>
            <property name="tooltip-text" translatable="yes">Stop reading aloud</property>
            <property name="visible">false</property>
            <signal name="clicked" handler="on_global_tts_stop_clicked"/>
            <style>
              <class name="destructive-action"/>
              <class name="circular"/>
            </style>
          </object>
        </child>
      </object>
    </child>
  </template>
</interface>
